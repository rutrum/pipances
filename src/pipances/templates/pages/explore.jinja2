{% extends "base.jinja2" %}
{% block title %}
  Explore - Pipances
{% endblock title %}
{% block content %}
  <div class="container mx-auto p-6">
    <h1 class="text-2xl font-bold mb-4">Explore</h1>
    {% include "explore/_explore_date_range.jinja2" %}
    {# Hidden inputs carrying current filter/sort state for HTMX includes #}
    <div id="explore-filters">
      <input type="hidden" name="sort" value="{{ sort }}">
      <input type="hidden" name="dir" value="{{ dir }}">
      {% if internal_filter %}<input type="hidden" name="internal" value="{{ internal_filter }}">{% endif %}
      {% if external_filter %}<input type="hidden" name="external" value="{{ external_filter }}">{% endif %}
      {% if category_filter %}<input type="hidden" name="category" value="{{ category_filter }}">{% endif %}
    </div>
    {# Vega-Embed scripts #}
    <script src="/static/js/vega.min.js"></script>
    <script src="/static/js/vega-lite.min.js"></script>
    <script src="/static/js/vega-embed.min.js"></script>
    {# Main content area (stats + charts + table) #}
    <div id="explore-content">{% include "explore/_explore_content.jinja2" %}</div>
  </div>
{% endblock content %}
