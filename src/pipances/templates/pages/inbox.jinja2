{% extends "base.jinja2" %}
{% block title %}
  Inbox - Pipances
{% endblock title %}
{% block initial_toast %}
  {% if toast == 'upload_success' and import_summary %}
    {% set imported = (import_summary.imported or '0')|int %}
    {% set duplicates = (import_summary.duplicates or '0')|int %}
    {% set parts = [] %}
    {% set _ = parts.append('Imported ' ~ imported ~ ' transaction' ~ ('s' if imported != 1 else '')) %}
    {% if duplicates > 0 %}{% set _ = parts.append(duplicates|string ~ ' duplicate' ~ ('s' if duplicates != 1 else '') ~ ' skipped') %}{% endif %}
    {% if import_summary.date_min and import_summary.date_max %}{% set _ = parts.append(import_summary.date_min ~ ' to ' ~ import_summary.date_max) %}{% endif %}
    {% if import_summary.account %}{% set _ = parts.append(import_summary.account) %}{% endif %}
    <div class="alert alert-success">
      <span>{{ parts | join(' · ') }}</span>
    </div>
  {% endif %}
{% endblock %}
{% block content %}
  <div class="container mx-auto p-6">
    {% if not transactions %}
      <div class="flex flex-col items-center justify-center py-16 text-base-content/60">
        <i data-lucide="inbox" class="w-16 h-16 mb-4"></i>
        <p class="text-xl font-semibold mb-2">All cleaned up!</p>
        <p class="mb-4">No pending transactions to review.</p>
        <a href="/upload" class="btn btn-primary">Upload transactions</a>
      </div>
    {% else %}
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-bold">Inbox</h1>
        <button class="btn btn-secondary"
                hx-post="/inbox/retrain"
                hx-swap="none"
                hx-include="#filter-bar">Retrain</button>
        <button class="btn btn-primary"
                hx-get="/inbox/commit-summary"
                hx-target="#commit-dialog-container"
                hx-swap="innerHTML">Commit</button>
      </div>
      <div id="commit-dialog-container"></div>
      <div id="inbox-message"></div>
      <div id="filter-bar"
           class="flex flex-wrap items-center gap-4 p-3 bg-base-200 rounded-lg mb-2">
        <span class="text-sm font-semibold whitespace-nowrap">Filter:</span>
        <input type="hidden"
               id="filter-sort"
               name="sort"
               value="{{ sort|default('date') }}">
        <input type="hidden"
               id="filter-dir"
               name="dir"
               value="{{ dir|default('asc') }}">
        <input type="hidden"
               id="filter-page"
               name="page"
               value="{{ page|default(1) }}">
        <input type="date"
               id="filter-date-from"
               name="date_from"
               value="{{ date_from|default('') }}"
               class="input input-bordered input-sm"
               placeholder="From"
               hx-get="/inbox"
               hx-trigger="change"
               hx-target="#inbox-table"
               hx-swap="innerHTML"
               hx-include="#filter-bar, #inbox-pagination-page-size"
               hx-push-url="true">
        <input type="date"
               id="filter-date-to"
               name="date_to"
               value="{{ date_to|default('') }}"
               class="input input-bordered input-sm"
               placeholder="To"
               hx-get="/inbox"
               hx-trigger="change"
               hx-target="#inbox-table"
               hx-swap="innerHTML"
               hx-include="#filter-bar, #inbox-pagination-page-size"
               hx-push-url="true">
        <select id="filter-internal"
                name="internal_id"
                class="select select-sm"
                hx-get="/inbox"
                hx-trigger="change"
                hx-target="#inbox-table"
                hx-swap="innerHTML"
                hx-include="#filter-bar, #inbox-pagination-page-size"
                hx-push-url="true">
          <option value="">All accounts</option>
          {% for acct in internal_accounts %}
            <option value="{{ acct.id }}"
                    {% if internal_id|default('') == acct.id|string %}selected{% endif %}>{{ acct.name }}</option>
          {% endfor %}
        </select>
        <select id="filter-import"
                name="import_id"
                class="select select-sm"
                hx-get="/inbox"
                hx-trigger="change"
                hx-target="#inbox-table"
                hx-swap="innerHTML"
                hx-include="#filter-bar, #inbox-pagination-page-size"
                hx-push-url="true">
          <option value="">All imports</option>
          {% for imp in imports %}
            <option value="{{ imp.id }}"
                    {% if import_id|default('') == imp.id|string %}selected{% endif %}>
              {{ imp.institution }} ({{ imp.imported_at.strftime("%Y-%m-%d") }})
            </option>
          {% endfor %}
        </select>
        <a href="/inbox" class="btn btn-sm btn-ghost">Clear</a>
      </div>
      <div id="bulk-toolbar"
           class="flex items-center gap-4 p-3 bg-base-300 rounded-lg mb-2">
        <span id="bulk-count" class="text-sm font-semibold whitespace-nowrap">0 selected</span>
        <input type="text"
               id="bulk-description"
               name="description"
               class="input input-bordered input-sm"
               placeholder="Description"
               disabled>
        <input type="text"
               id="bulk-category"
               name="category"
               class="input input-bordered input-sm"
               placeholder="Category"
               disabled>
        <input type="text"
               id="bulk-external"
               name="external"
               class="input input-bordered input-sm"
               placeholder="External"
               disabled>
        <button id="bulk-apply-btn"
                class="btn btn-sm btn-primary"
                disabled
                hx-patch="/transactions/bulk"
                hx-include=".select-txn:checked, #bulk-description, #bulk-category, #bulk-external"
                hx-swap="none">Apply</button>
        <button id="bulk-approve-btn"
                class="btn btn-sm btn-outline btn-success"
                disabled
                hx-patch="/transactions/bulk"
                hx-include=".select-txn:checked"
                hx-vals='{"marked_for_approval": "true"}'
                hx-swap="none">Approve Selected</button>
      </div>
      <table class="table table-fixed w-full">
        <thead>
          {% include "inbox/_inbox_thead.jinja2" %}
        </thead>
        <tbody id="inbox-table">
          {% for txn in transactions %}
            {% include "inbox/_inbox_row.jinja2" %}
          {% endfor %}
        </tbody>
      </table>
      <div id="inbox-pagination">
        {% set pagination_url = "/inbox" %}
        {% set pagination_target = "#inbox-table" %}
        {% set pagination_include = "#filter-bar" %}
        {% set pagination_id = "inbox-pagination" %}
        {% include "shared/_pagination.jinja2" %}
      </div>
      <script>
      (function() {
        var toolbar = document.getElementById('bulk-toolbar');
        var countEl = document.getElementById('bulk-count');
        var tbody = document.getElementById('inbox-table');

        function getSelectAll() {
          return document.getElementById('select-all');
        }

        function getCheckboxes() {
          return tbody.querySelectorAll('.select-txn');
        }

        function getSelectedIds() {
          var ids = [];
          getCheckboxes().forEach(function(cb) {
            if (cb.checked) ids.push(cb.dataset.txnId);
          });
          return ids;
        }

        var bulkInputs = toolbar.querySelectorAll('input, button');

        function updateToolbar() {
          var ids = getSelectedIds();
          var hasSelection = ids.length > 0;
          countEl.textContent = ids.length + ' selected';
          bulkInputs.forEach(function(el) { el.disabled = !hasSelection; });
          // Sync select-all state
          var selectAll = getSelectAll();
          var boxes = getCheckboxes();
          selectAll.checked = boxes.length > 0 && ids.length === boxes.length;
          selectAll.indeterminate = ids.length > 0 && ids.length < boxes.length;
        }

        // Use event delegation on document so it survives OOB swaps of thead
        document.addEventListener('change', function(e) {
          if (e.target.id === 'select-all') {
            var checked = e.target.checked;
            getCheckboxes().forEach(function(cb) {
              cb.checked = checked;
            });
            updateToolbar();
          } else if (e.target.classList.contains('select-txn')) {
            updateToolbar();
          }
        });

        // Re-sync toolbar after HTMX primary swaps (filter/pagination)
        document.addEventListener('htmx:afterSwap', function(e) {
          if (e.detail.target === tbody || tbody.contains(e.detail.target)) {
            updateToolbar();
          }
        });

        // Re-sync toolbar and clear inputs after bulk HTMX requests
        document.addEventListener('htmx:afterRequest', function(e) {
          var elt = e.detail.elt;
          if (!elt) return;
          if (elt.id === 'bulk-apply-btn' || elt.id === 'bulk-approve-btn') {
            updateToolbar();
            if (elt.id === 'bulk-apply-btn' && e.detail.successful) {
              document.getElementById('bulk-description').value = '';
              document.getElementById('bulk-category').value = '';
              document.getElementById('bulk-external').value = '';
            }
          }
        });
      })();
      </script>
      <!-- Modal container for transaction edit modal -->
      <div id="edit-modal-container"></div>
    {% endif %}
  </div>
{% endblock content %}
